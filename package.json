{
  "name": "inkubus",
  "version": "0.1.0",
  "description": "Inkubus — goal-aligned writing app. FastAPI backend, React frontend, Electron shell.",
  "main": "electron/main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "bash setup.sh",
    "predev": "bash scripts/predev.sh",
    "predev:web": "bash scripts/predev.sh",
    "dev:backend": "cd backend && .venv/bin/python -m uvicorn app:app --reload --port 8741",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on tcp:5173 http-get://localhost:8741/api/health && ELECTRON_DEV=1 electron .",
    "dev": "concurrently -k -n backend,web,electron -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:web": "concurrently -k -n backend,web -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "bash scripts/build-backend.sh",
    "make-icon": "bash scripts/make-icon.sh",
    "dist": "npm run build:backend && npm run build:frontend && electron-builder",
    "dist:dir": "npm run build:backend && npm run build:frontend && electron-builder --dir",
    "start": "ELECTRON_DEV= electron ."
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.lilithforge.inkubus",
    "productName": "Inkubus",
    "afterPack": "build/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist/inkubus-backend",
        "to": "inkubus-backend"
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "dmg": {
      "title": "Inkubus ${version}"
    }
  },
  "dependencies": {
    "resend": "^6.14.0"
  }
}
