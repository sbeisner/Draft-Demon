{
  "name": "draft-demon",
  "version": "0.0.0",
  "description": "Draft Demon — goal-aligned writing app. FastAPI backend, React frontend, Electron shell.",
  "main": "electron/main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "bash setup.sh",
    "predev": "bash scripts/predev.sh",
    "predev:web": "bash scripts/predev.sh",
    "dev:backend": "cd backend && .venv/bin/python -m uvicorn app:app --reload --port 8741",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on tcp:5173 http-get://localhost:8741/api/health && ELECTRON_DEV=1 electron .",
    "dev": "concurrently -k -n backend,web,electron -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:web": "concurrently -k -n backend,web -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "dist": "npm run build:frontend && electron-builder",
    "dist:dir": "npm run build:frontend && electron-builder --dir",
    "start": "ELECTRON_DEV= electron ."
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.draftdemon.app",
    "productName": "Draft Demon",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!*.db",
          "!*.db-journal",
          "!*.db-wal",
          "!*.db-shm"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/assets/icon.png",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Draft Demon ${version}"
    }
  },
  "dependencies": {
    "resend": "^6.14.0"
  }
}
